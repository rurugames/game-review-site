<style>
.product-form-container {
  max-width: 760px;
  margin: 0 auto;
  padding: 1.5rem 1rem;
}
.product-form-container h1 {
  margin-bottom: 1.25rem;
}
.form-group {
  margin-bottom: 1.1rem;
}
.form-group label {
  display: block;
  font-weight: bold;
  margin-bottom: 0.3rem;
}
.form-group input[type="text"],
.form-group input[type="url"],
.form-group textarea {
  width: 100%;
  padding: 0.5rem 0.65rem;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 0.95rem;
  box-sizing: border-box;
}
.form-group textarea {
  resize: vertical;
}
.form-hint {
  font-size: 0.8rem;
  color: #888;
  margin-top: 0.25rem;
}
.form-actions {
  display: flex;
  gap: 0.75rem;
  margin-top: 1.5rem;
  flex-wrap: wrap;
}
.star-rating-input {
  display: flex;
  flex-direction: row-reverse;
  justify-content: flex-end;
  gap: 2px;
  margin: 6px 0 4px;
}
.star-rating-input input[type="radio"] { display: none; }
.star-rating-input label {
  font-size: 2.2rem;
  color: #ccc;
  cursor: pointer;
  transition: color 0.1s;
  line-height: 1;
}
.star-rating-input input:checked ~ label,
.star-rating-input label:hover,
.star-rating-input label:hover ~ label {
  color: #f5a623;
}
</style>

<div class="product-form-container">
  <h1>商品レビューを追加</h1>

  <form action="/products" method="POST">
    <div class="form-group">
      <label for="title">タイトル <span style="color:red">*</span></label>
      <input type="text" id="title" name="title" required
             placeholder="例: ○○ ～サークル名の最新作～">
    </div>

    <div class="form-group">
      <label for="affiliateLink">アフィリエイトリンク（URL） <span style="color:red">*</span></label>
      <input type="url" id="affiliateLink" name="affiliateLink" required
             placeholder="https://www.dlsite.com/maniax/work/=/product_id/RJxxxxxxxx.html">
      <p class="form-hint">DLsite 作品ページ URL を貼ると自動でアフィリエイト ID が付与されます。</p>
    </div>

    <div class="form-group">
      <label for="body">レビュー・感想本文 <span style="color:red">*</span></label>
      <p class="form-hint">Markdown 形式で記述できます。</p>
      <textarea id="body" name="body" rows="16" required
                placeholder="## おすすめポイント&#10;- ここに感想を書く&#10;&#10;## こんな人に向いている&#10;- ..."></textarea>
    </div>

    <div class="form-group">
      <label>評価（★）<span style="font-size:0.8rem;color:#888;margin-left:6px;">未選択でも投稿可</span></label>
      <div class="star-rating-input">
        <% for (let i = 5; i >= 1; i--) { %>
          <input type="radio" name="rating" id="star<%= i %>" value="<%= i %>">
          <label for="star<%= i %>">★</label>
        <% } %>
      </div>
    </div>

    <div class="form-group">
      <label for="status">公開ステータス</label>
      <select id="status" name="status">
        <option value="published">公開</option>
        <option value="draft">下書き</option>
      </select>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary">投稿する</button>
      <a href="/products" class="btn-secondary">キャンセル</a>
    </div>
  </form>
</div>
