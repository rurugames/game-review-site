<style>
.products-container {
  max-width: 960px;
  margin: 0 auto;
  padding: 1.5rem 1rem;
}
.products-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}
.product-card {
  background: #fff;
  border-radius: 10px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.15s, box-shadow 0.15s;
}
.product-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 6px 16px rgba(0,0,0,0.13);
}
.product-card-thumb {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  background: #f0f0f0;
}
.product-card-thumb-placeholder {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: linear-gradient(135deg, #e8e8e8, #d4d4d4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  color: #aaa;
}
.product-card-body {
  padding: 0.9rem 1rem 1rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.product-card-title {
  font-size: 1rem;
  font-weight: bold;
  margin: 0 0 0.5rem;
  line-height: 1.4;
}
.product-card-title a {
  color: #1a3a6e;
  text-decoration: none;
}
.product-card-title a:hover { text-decoration: underline; }
.product-card-meta {
  font-size: 0.78rem;
  color: #888;
  margin-bottom: 0.5rem;
}
.product-genre {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: bold;
  color: #fff;
  background: #7b5ea7;
  border-radius: 3px;
  padding: 1px 6px;
  margin-right: 4px;
  vertical-align: middle;
}
.product-card-rating {
  font-size: 0.85rem;
  color: #e8a020;
  margin-bottom: 0.5rem;
  letter-spacing: 0.05em;
}
.product-card-rating .rating-val {
  color: #888;
  font-size: 0.78rem;
  margin-left: 0.3rem;
}
.product-card-actions {
  margin-top: auto;
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}
</style>

<div class="products-container">
  <% if (isAdultConfirmed) { %>
  <div style="text-align:center; margin-bottom: 20px;">
    <ins class="dmm-widget-placement" data-id="b8b1260321bb60a9e25f448289f145bb" style="background:transparent"></ins>
    <script src="https://widget-view.dmm.co.jp/js/placement.js" class="dmm-widget-scripts" data-id="b8b1260321bb60a9e25f448289f145bb"></script>
  </div>
  <% } %>

  <div class="products-header">
    <h1>商品レビュー</h1>
    <% if (isAdmin) { %>
      <a href="/products/new" class="btn-primary">＋ 追加</a>
    <% } %>
  </div>

  <% if (products.length === 0) { %>
    <p>まだ投稿がありません。</p>
  <% } else { %>
    <%
      const GENRE_ORDER = ['FANZA同人', '同人ゲーム', 'PCゲーム', '成年コミック', 'FANZAブックス', 'DLsite', 'その他'];
      const grouped = {};
      products.forEach(p => {
        const g = p.genre || getProductGenre(p.affiliateLink);
        if (!grouped[g]) grouped[g] = [];
        grouped[g].push(p);
      });
      const displayGenres = GENRE_ORDER.filter(g => grouped[g] && grouped[g].length > 0);
      Object.keys(grouped).forEach(g => { if (!GENRE_ORDER.includes(g) && grouped[g].length > 0) displayGenres.push(g); });
    %>

    <% displayGenres.forEach(genre => { %>
      <section style="margin-bottom: 2.5rem;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom: 1rem; border-bottom: 2px solid #7b5ea7; padding-bottom: 0.4rem;">
          <h2 style="margin:0; font-size:1.15rem; color:#7b5ea7;">&#127775; <%= genre %> <span style="font-size:0.85rem; color:#999; font-weight:normal;">（<%= grouped[genre].length %>件）</span></h2>
        </div>
        <div class="products-grid">
          <% grouped[genre].forEach((p, index) => { %>
            <% if (index === 4 && typeof adTag !== 'undefined' && adTag) { %>
              <div class="product-ad-banner" style="grid-column: 1 / -1; text-align: center; margin: 0.5rem 0;">
                <%- adTag %>
              </div>
            <% } %>
            <div class="product-card">
              <% if (p.imageUrl) { %>
                <a href="<%= p.affiliateLink %>" target="_blank" rel="noopener sponsored" style="display:block;">
                  <img class="product-card-thumb" src="<%= p.imageUrl %>" alt="<%= p.title %>" loading="lazy">
                </a>
              <% } else { %>
                <div class="product-card-thumb-placeholder">&#127775;</div>
              <% } %>
              <div class="product-card-body">
                <h2 class="product-card-title">
                  <a href="/products/<%= p._id %>"><%= p.title %></a>
                </h2>
                <div class="product-card-meta">
                  <span class="product-genre"><%= p.genre || getProductGenre(p.affiliateLink) %></span>
                  &nbsp;<%= new Date(p.createdAt).toLocaleDateString('ja-JP') %>
                </div>
                <% if (p.rating) { %>
                <% const _n = Math.min(5, Math.max(0, Math.round(p.rating))); %>
                <div class="product-card-rating">
                  <span><%= '★'.repeat(_n) + '☆'.repeat(5 - _n) %></span>
                  <span class="rating-val"><%= p.rating.toFixed(1) %></span>
                </div>
                <% } %>
                <div class="product-card-actions">
                  <a href="/products/<%= p._id %>" class="btn-secondary">詳細を見る</a>
                  <a href="<%= p.affiliateLink %>" class="btn-primary" target="_blank" rel="noopener sponsored">購入・詳細</a>
                  <% if (isAdmin) { %>
                    <form action="/products/<%= p._id %>" method="POST"
                          onsubmit="return confirm('削除しますか？')" style="margin:0">
                      <input type="hidden" name="_method" value="DELETE">
                      <button type="submit" class="btn-delete" style="cursor:pointer;">削除</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% }) %>
  <% } %>
</div>
