<style>
.product-show-container {
  max-width: 820px;
  margin: 0 auto;
  padding: 1.5rem 1rem;
}
/* 関連動画ウィジェット */
.rec-video-section { margin-top: 2rem; }
.rec-video-section-title {
  font-size: 0.9rem;
  font-weight: bold;
  color: #ff4e6a;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.75rem;
}
.rec-video-widget {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  background: #1a1a2e;
  border-radius: 10px;
  padding: 14px;
  margin-bottom: 10px;
  text-decoration: none;
  color: inherit;
  transition: background 0.2s;
}
.rec-video-widget:hover { background: #22223b; }
.rec-video-thumb {
  width: 140px;
  flex-shrink: 0;
  border-radius: 6px;
  overflow: hidden;
}
.rec-video-thumb img {
  width: 100%;
  display: block;
  object-fit: cover;
  aspect-ratio: 16/9;
}
.rec-video-body { flex: 1; min-width: 0; }
.rec-video-label {
  font-size: 11px;
  color: #ff4e6a;
  font-weight: bold;
  letter-spacing: 0.05em;
  margin-bottom: 6px;
}
.rec-video-title {
  font-size: 14px;
  font-weight: bold;
  color: #fff;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.rec-video-date { font-size: 11px; color: #999; margin-top: 6px; }
@media (max-width: 480px) { .rec-video-thumb { width: 100px; } }
.product-show-header {
  margin-bottom: 1.25rem;
}
.product-show-title {
  font-size: 1.5rem;
  font-weight: bold;
  margin: 0 0 0.4rem;
  line-height: 1.35;
}
.product-show-meta {
  font-size: 0.82rem;
  color: #888;
  margin-bottom: 0.4rem;
}
.product-genre {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: bold;
  color: #fff;
  background: #7b5ea7;
  border-radius: 3px;
  padding: 1px 7px;
  margin-right: 6px;
  vertical-align: middle;
}
.product-show-rating {
  font-size: 1rem;
  color: #e8a020;
  margin-bottom: 0.75rem;
  letter-spacing: 0.05em;
}
.product-show-rating .rating-val {
  color: #888;
  font-size: 0.82rem;
  margin-left: 0.4rem;
}
.link-card {
  display: block;
  border: 1px solid #e1e8ed;
  border-radius: 12px;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  margin-bottom: 1.5rem;
  transition: background 0.15s;
}
.link-card:hover {
  background: #f7f9fa;
}
.link-card-image {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}
.link-card-body {
  padding: 0.75rem 1rem;
}
.link-card-title {
  font-size: 0.95rem;
  font-weight: bold;
  margin-bottom: 0.25rem;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.link-card-domain {
  font-size: 0.78rem;
  color: #888;
}
.product-show-affiliate {
  margin-bottom: 1.5rem;
}
.product-show-body {
  line-height: 1.75;
  font-size: 0.97rem;
}
.product-show-body h2 { margin-top: 1.5rem; }
.product-show-body p  { margin: 0.6rem 0; }
.product-show-actions {
  margin-top: 2rem;
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}
</style>

<div class="product-show-container">
  <div class="product-show-header">
    <h1 class="product-show-title"><%= product.title %></h1>
    <div class="product-show-meta">
      <span class="product-genre"><%= product.genre || getProductGenre(product.affiliateLink) %></span>
      &nbsp;<%= new Date(product.createdAt).toLocaleDateString('ja-JP') %>
    </div>
    <% if (product.rating) { %>
    <% const _n = Math.min(5, Math.max(0, Math.round(product.rating))); %>
    <div class="product-show-rating">
      <span><%= '★'.repeat(_n) + '☆'.repeat(5 - _n) %></span>
      <span class="rating-val">おすすめ度 <%= product.rating.toFixed(1) %> / 5.0</span>
    </div>
    <% } %>
  </div>

  <% if (product.imageUrl) { %>
    <% let _hostname = ''; try { _hostname = new URL(product.affiliateLink).hostname; } catch(e) {} %>
    <a href="<%= product.affiliateLink %>" target="_blank" rel="noopener sponsored" class="link-card">
      <img class="link-card-image" src="<%= product.imageUrl %>" alt="<%= product.title %>" loading="lazy">
      <div class="link-card-body">
        <div class="link-card-title"><%= product.title %></div>
        <div class="link-card-domain"><%= _hostname %></div>
      </div>
    </a>
  <% } else { %>
    <div class="product-show-affiliate">
      <a href="<%= product.affiliateLink %>" class="btn-primary" target="_blank" rel="noopener sponsored">
        &#9654; 購入・詳細ページへ
      </a>
    </div>
  <% } %>

  <div class="product-show-affiliate-cta" style="margin-bottom:1.25rem;">
    <a href="<%= product.affiliateLink %>" class="btn-primary" target="_blank" rel="noopener sponsored">&#9654; 購入・詳細ページへ</a>
  </div>

  <div class="product-show-body">
    <%- bodyHtml %>
  </div>

  <% if (typeof adTag !== 'undefined' && adTag) { %>
  <div class="product-show-ad" style="text-align:center; margin: 1.5rem 0;">
    <%- adTag %>
  </div>
  <% } %>

  <div class="product-show-actions">
    <a href="/products" class="btn-secondary">← 一覧に戻る</a>
    <% if (isAdmin) { %>
      <form action="/products/<%= product._id %>" method="POST"
            onsubmit="return confirm('この投稿を削除しますか？')">
        <input type="hidden" name="_method" value="DELETE">
        <button type="submit" class="btn-delete" style="cursor:pointer;">削除</button>
      </form>
    <% } %>
  </div>

  <% if (typeof productVideos !== 'undefined' && productVideos && productVideos.length > 0) { %>
  <div class="rec-video-section">
    <div class="rec-video-section-title">
      ▶ <%= videosAreRelated ? '関連動画' : 'おすすめ動画' %>
    </div>
    <% productVideos.forEach(function(v) { %>
      <a href="<%= v.url %>" target="_blank" rel="noopener" class="rec-video-widget">
        <div class="rec-video-thumb">
          <% if (v.thumbnailUrl) { %>
            <img src="<%= v.thumbnailUrl %>" alt="<%= v.title %>" loading="lazy">
          <% } else { %>
            <img src="/images/siteicon.svg" alt="thumb" loading="lazy">
          <% } %>
        </div>
        <div class="rec-video-body">
          <div class="rec-video-label">▶ <%= videosAreRelated ? '関連動画' : 'おすすめ動画' %></div>
          <div class="rec-video-title"><%= v.title %></div>
          <div class="rec-video-date"><%= v.publishedAtJp || '' %></div>
        </div>
      </a>
    <% }) %>
  </div>
  <% } %>
</div>
