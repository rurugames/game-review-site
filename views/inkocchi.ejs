  function drawFX(){
    const t=S.tick;
    if(S.fx==='feed'){
      for(let i=0;i<5;i++){
        const y=((t*1.5+i*22)%80)-10, x=100+i*18+Math.sin(t*0.1+i)*6;
        sq(x,y+30,5,5,'#ffe050'); sq(x+2,y+28,3,3,'#ffcc00');
      }
      ctx.fillStyle='#ffd700'; ctx.font='bold 11px Courier New'; ctx.fillText('もぐもぐ...',90,28);
    } else if(S.fx==='play'){
      const bx=CX+S.motionX, by=CY-55+S.motionY;
      for(let i=0;i<8;i++){
        const a=(i/8)*Math.PI*2+t*0.07, dist=16+((t*1.2+i*6)%22);
        ctx.globalAlpha=Math.max(0,0.5+Math.sin(t*0.12+i)*0.5);
        sq(bx+Math.cos(a)*dist-2,by+Math.sin(a)*dist*0.6-2,4,4,i%2===0?'#ffd700':'#ff88ff');
      }
      ctx.globalAlpha=1; ctx.fillStyle='#ffd700'; ctx.font='bold 11px Courier New';
      ctx.textAlign='center'; ctx.fillText('たのしいな！',CX,20); ctx.textAlign='left';
    } else if(S.sleeping||S.fx==='sleep'){
      [['z',CX+16,CY-55],[' z',CX+24,CY-70],['Z',CX+34,CY-82]].forEach(([c,x,y],i)=>{
        const phase=((t*0.025+i*0.5)%1);
        ctx.globalAlpha=Math.max(0,Math.sin(phase*Math.PI)*0.8);
        ctx.fillStyle='#aaddff'; ctx.font=`bold ${10+i*4}px Courier New`; ctx.fillText(c,x,y-phase*12);
      });
      ctx.globalAlpha=1;
    } else if(S.fx==='evolve'){
      for(let i=0;i<12;i++){
        const angle=(i/12)*Math.PI*2+t*0.05, dist=20+((t*2)%50);
        const x=CX+Math.cos(angle)*dist, y=(CY-40)+Math.sin(angle)*dist*0.6;
        ctx.globalAlpha=Math.max(0,1-(t%30)/30);
        sq(x-2,y-2,4,4,i%2===0?'#ffd700':'#ffffff');
      }
      ctx.globalAlpha=1;
    }
    if(S.fx==='water'){
      for(let i=0;i<6;i++){
        const bpx=40+Math.floor((t*1.4+i*32)%200), bpy=H-28-((t*0.9+i*18)%38);
        ctx.globalAlpha=Math.max(0,0.25+Math.sin(t*0.15+i)*0.3);
        ctx.strokeStyle='#88ddff'; ctx.lineWidth=1.5;
        ctx.beginPath(); ctx.arc(bpx,bpy,1.5+i%3,0,Math.PI*2); ctx.stroke();
      }
      ctx.globalAlpha=1; ctx.lineWidth=1;
      ctx.fillStyle='#88ddff'; ctx.font='bold 11px Courier New';
      ctx.textAlign='center'; ctx.fillText('きれいきれい！',CX,20); ctx.textAlign='left';
    }
    if(S.fx==='pet'){
      const bx=CX+S.motionX, by=CY-50+S.motionY;
      for(let i=0;i<5;i++){
        const hy=((t*0.7+i*12)%45), hx=bx+(i%2===0?-1:1)*((Math.floor(i/2)+1)*9);
        ctx.globalAlpha=Math.max(0,(1-hy/45)*0.9);
        ctx.fillStyle=['#ff88aa','#ff99cc','#ffaad4','#ff77bb','#ff66aa'][i];
        ctx.font=`${10+i%3*2}px Courier New`;
        ctx.textAlign='center'; ctx.fillText('♥',hx,by-hy);
      }
      ctx.globalAlpha=1; ctx.textAlign='left';
    }
    if(!S.sleeping&&S.stage>0&&S.hunger>80&&S.happy>80&&S.energy>80){
      for(let i=0;i<3;i++){
        const hy=((t*0.4+i*20)%55), hx=75+i*65;
        ctx.globalAlpha=Math.max(0,(1-hy/55)*0.8);
        ctx.fillStyle='#ff88aa'; ctx.font='14px Courier New';
        ctx.textAlign='center'; ctx.fillText('♥',hx,H-25-hy);
      }
      ctx.globalAlpha=1; ctx.textAlign='left';
    }
  }

  // ─── SWING ─────────────────────────────────
  function drawSwingFrame(){
    const angle=Math.sin(S.tick*0.05)*0.45;
    const px=CX, py=22, rl=72;
    const sx=Math.sin(angle)*rl, sy=Math.cos(angle)*rl;
    // 支柱
    ctx.strokeStyle='#553399'; ctx.lineWidth=4;
    ctx.beginPath(); ctx.moveTo(px-40,py); ctx.lineTo(px+40,py); ctx.stroke();
    ctx.lineWidth=3;
    ctx.beginPath(); ctx.moveTo(px-40,0); ctx.lineTo(px-40,py); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(px+40,0); ctx.lineTo(px+40,py); ctx.stroke();
    // チェーン
    ctx.strokeStyle='#aa8844'; ctx.lineWidth=2;
    const r1x=px-18, r2x=px+18;
    ctx.beginPath(); ctx.moveTo(r1x,py); ctx.lineTo(r1x+sx,py+sy); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(r2x,py); ctx.lineTo(r2x+sx,py+sy); ctx.stroke();
    // 座面
    const scx=px+sx, scy=py+sy;
    ctx.save(); ctx.translate(scx,scy); ctx.rotate(angle);
    ctx.fillStyle='#774422'; ctx.fillRect(-22,-5,44,9);
    ctx.fillStyle='#aa6633'; ctx.fillRect(-22,-5,44,4);
    ctx.restore();
  }

  // ─── BOWLS / POOPS ─────────────────────────
  function drawBowls(){
    const fy=H-17, bw=36, bh=13;
    function bowl(bx, level, fillHi, fillLo, label, warn){
      ctx.fillStyle='#1a2a3e'; ctx.fillRect(bx,fy,bw,bh);
      ctx.fillStyle='#0e1e2e'; ctx.fillRect(bx+2,fy+2,bw-4,bh-2);
      if(level>0){
        const fh=Math.max(1,Math.round((bh-4)*level/100));
        ctx.fillStyle=level<20?fillLo:fillHi;
        ctx.fillRect(bx+2,fy+bh-2-fh,bw-4,fh);
        if(level>10){
          ctx.globalAlpha=0.35+Math.sin(S.tick*0.12)*0.15;
          ctx.fillStyle='#ffffff'; ctx.fillRect(bx+2,fy+bh-2-fh,bw-4,1);
          ctx.globalAlpha=1;
        }
      }
      ctx.fillStyle='#334455'; ctx.fillRect(bx,fy+bh-1,bw,1);
      ctx.fillStyle=level<20?warn:'#7799aa'; ctx.font='7px Courier New';
      ctx.textAlign='center'; ctx.fillText(label+' '+Math.round(level)+'%',bx+bw/2,fy-3);
      ctx.textAlign='left';
    }
    bowl(12,   S.bowl,  '#cc8822','#882200','🌾','#ff6633');
    bowl(W-48, S.water, '#2266cc','#113388','💧','#4488ff');
  }

  function drawPoops(){
    S.poops.forEach(p=>{
      ctx.fillStyle='#3a1800';
      ctx.beginPath(); ctx.ellipse(p.x,p.y,4,2.5,0,0,Math.PI*2); ctx.fill();
      ctx.fillStyle='#5a2e00';
      ctx.beginPath(); ctx.ellipse(p.x,p.y-2,2.5,1.8,0,0,Math.PI*2); ctx.fill();
      ctx.fillStyle='#7a4010';
      ctx.beginPath(); ctx.ellipse(p.x-0.5,p.y-3.2,1.5,1.2,0,0,Math.PI*2); ctx.fill();
    });
    if(S.poops.length>=4){
      ctx.globalAlpha=0.45; ctx.fillStyle='#889966'; ctx.font='10px Courier New';
      ctx.fillText('～',CX-35,H-32+Math.sin(S.tick*0.08)*4);
      ctx.fillText('～',CX+22,H-38+Math.sin(S.tick*0.08+1.2)*4);
      ctx.globalAlpha=1;
    }
  }

  // ─── MOTION ─────────────────────────────────
  function updateMotion(){
    if(S.stage===0||S.dead){ S.motionX=0; S.motionY=0; S.motion='idle'; return; }

    // ブランコ乗り中（あそぶ FX）
    if(S.fx==='play'){
      const angle=Math.sin(S.tick*0.05)*0.45;
      const rl=72, py=22;
      S.motionX=Math.sin(angle)*rl;
      const sy=Math.cos(angle)*rl, seatY=py+sy;
      // 各ステージの足元 Y = stageBaseOY + feetOffset に seatY を合わせる
      const feetRef=S.stage===1?(CY-52+42):S.stage===2?(CY-66+68):(CY-78+78);
      S.motionY=seatY-feetRef;
      S.motion='play';
      return;
    }

    if(S.sleeping){ S.motionX=0; S.motionY=0; S.motion='idle'; return; }

    S.motionTimer--;
    S.motionPhase++;
    if(S.motionTimer<=0){
      const r=Math.random();
      if(r<0.28){      S.motion='idle'; S.motionTimer=80+Math.floor(Math.random()*80); }
      else if(r<0.46){ S.motion='jump'; S.motionTimer=36+Math.floor(Math.random()*24); }
      else if(r<0.62){ S.motion='fly';  S.motionTimer=55+Math.floor(Math.random()*35); }
      else if(r<0.80){ S.motion='run';  S.motionTimer=55+Math.floor(Math.random()*45); }
      else{            S.motion='walk'; S.motionTimer=70+Math.floor(Math.random()*60); }
      S.motionPhase=0;
    }
    switch(S.motion){
      case 'jump':
        S.motionX=0;
        S.motionY=-Math.abs(Math.sin(S.motionPhase*0.13))*18;
        break;
      case 'fly':
        S.motionX=Math.sin(S.motionPhase*0.05)*40;
        S.motionY=-18+Math.sin(S.motionPhase*0.07)*8;
        break;
      case 'run':
        S.motionX=Math.sin(S.motionPhase*0.09)*44;
        S.motionY=-Math.abs(Math.sin(S.motionPhase*0.18))*6;
        break;
      case 'walk':
        S.motionX=Math.sin(S.motionPhase*0.045)*26;
        S.motionY=-Math.abs(Math.sin(S.motionPhase*0.09))*3;
        break;
      default:
        S.motionX=0; S.motionY=0;
    }
  }

  // ─── LOGIC ─────────────────────────────────
  function decayTick(){
    if(S.stage===0||S.dead) return;
    let bathed=false;
    if(S.sleeping){
      S.energy=Math.min(100,S.energy+12);
      S.hunger=Math.max(0,S.hunger-1);
      S.water=Math.max(0,S.water-0.5);
    } else {
      S.happy=Math.max(0,S.happy-1);
      S.energy=Math.max(0,S.energy-2);
      S.hunger=Math.max(0,S.hunger-1);
      // えさいれから自動で食べる
      if(S.bowl>0){
        S.bowl=Math.max(0,S.bowl-2);
        S.hunger=Math.min(100,S.hunger+2);
        if(Math.random()<0.25&&!S.fx) S.eatPhase=20;
      } else {
        S.hunger=Math.max(0,S.hunger-3);
      }
      // みずいれ（徐々に減少）
      S.water=Math.max(0,S.water-1.5);
      // 水を飲む（ランダム20%で清潔度微回復）
      if(S.water>0&&Math.random()<0.2) S.clean=Math.min(100,S.clean+5);
      // 水浴び（水80%以上・5%確率）
      if(S.water>=80&&Math.random()<0.05&&!S.fx){
        S.water=Math.max(0,S.water-8);
        S.clean=Math.min(100,S.clean+40+Math.round(Math.random()*20));
        S.fx='water'; setTimeout(()=>{ if(S.fx==='water') S.fx=null; },2000);
        bathed=true;
      }
      // フン
      poopTick++;
      if(poopTick>=poopInterval&&S.poops.length<6){
        poopTick=0; poopInterval=3+Math.floor(Math.random()*5);
        S.poops.push({x:Math.round(80+Math.random()*120), y:Math.round(H-13+Math.random()*4)});
        S.clean=Math.max(0,S.clean-12);
      }
    }
    // 清潔度の自然減少（フンが多いほど速い）
    S.clean=Math.max(0,S.clean-(0.3+S.poops.length*0.15));
    // 清潔度が低いとストレス
    if(S.clean<30&&!S.sleeping){
      S.happy=Math.max(0,S.happy-1);
      S.energy=Math.max(0,S.energy-1);
    }
    // 寿命管理
    if(S.stage>0){
      const anyZero=S.hunger===0||S.happy===0||S.energy===0||S.bowl===0;
      if(anyZero){
        S.lifePts-=3;
        if(S.lifePts<=-15){
          S.lifespan=Math.max(MIN_LIFESPAN,S.lifespan-1);
          S.lifePts=0;
          sndLifeDown(); msg('ほったらかし...寿命が縮んだ...');
        }
      } else if(S.hunger>60&&S.happy>60&&S.energy>60&&S.clean>60&&S.bowl>30){
        S.lifePts++;
        if(S.lifePts>=40){
          S.lifespan=Math.min(MAX_LIFESPAN,S.lifespan+1);
          S.lifePts=0;
          sndLifeUp(); msg('元気いっぱい！寿命が延びた！✨');
        }
      }
    }
    checkStatus(); updateUI();
    if(bathed) msg('みずあびしてるよ！きもちよさそう！');
  }

  function checkStatus(){
    if(S.clean<15)         msg('くさい...そうじしてほしいな...');
    else if(S.bowl<10)     msg('えさがないよ！おなかがすいてきた！');
    else if(S.water<10)    msg('みずがないよ～！のどかわいた！');
    else if(S.energy<15)   msg('つかれたよ...ねむいよ...');
    else if(S.hunger<15)   msg('おなかすいたよ～！');
    else if(S.happy<15)    msg('つまんないよ...あそんで！');
    else if(S.hunger>80&&S.happy>80&&S.energy>80&&S.clean>80) msg('げんきいっぱいだよ！');
  }

  function checkEvolve(){
    const next=S.stage+1; if(next>3) return;
    if(S.age>=STAGE_DAYS[next]){
      if(next===1){
        if(awaitingName) return;
        S.color=Math.random()<0.1?3:Math.floor(Math.random()*3);
        awaitingName=true;
        showNameOverlay();
        return;
      }
      S.stage=next; S.fx='evolve';
      setTimeout(()=>{ S.fx=null; },2000);
      msg(`✨ ${getStageName()}になったよ！`);
      const sc=document.getElementById('ikScreen');
      sc.style.boxShadow='0 0 30px #ffd700';
      setTimeout(()=>{ sc.style.boxShadow=''; },2500);
      updateUI();
    }
  }

  function checkRandomEvent(){
    if(S.stage===0||S.dead) return;
    if(Math.random()>0.2) return;
    const ev=EVENTS[Math.floor(Math.random()*EVENTS.length)];
    if(ev.hunger!=null) S.hunger=Math.max(0,Math.min(100,S.hunger+ev.hunger));
    if(ev.happy!=null) S.happy=Math.max(0,Math.min(100,S.happy+ev.happy));
    if(ev.energy!=null) S.energy=Math.max(0,Math.min(100,S.energy+ev.energy));
    msg(ev.msg); sndEvent(); updateUI();
  }

  function randomTalk(){
    if(S.stage===0||S.dead||S.sleeping) return;
    const t=TALKS[Math.floor(Math.random()*TALKS.length)];
    msg(S.name&&Math.random()<0.3?`${S.name}、${t}`:t);
    sndTalk();
  }

  // ─── CANVAS TAP ────────────────────────────
  let petCount=0, petTimer=null;
  function handleCanvasTap(e){
    e.preventDefault();
    if(S.dead) return;
    if(S.stage===0){ msg('まだたまごだよ...そっとしといて...'); return; }
    if(S.sleeping){ msg('...zzz...（ねてるよ）'); return; }
    const rect=canvas.getBoundingClientRect();
    const tx=(e.clientX-rect.left)*(W/rect.width);
    const ty=(e.clientY-rect.top)*(H/rect.height);
    const bx=CX+S.motionX, by=CY-40+S.motionY;
    const dist=Math.sqrt((tx-bx)**2+(ty-by)**2);
    if(dist<55){
      petCount++;
      clearTimeout(petTimer);
      petTimer=setTimeout(()=>{ petCount=0; },1200);
      if(petCount>=4){
        msg('くすぐったいよ～！'); S.motionTimer=0;
      } else {
        S.happy=Math.min(100,S.happy+3);
        S.fx='pet'; setTimeout(()=>{ if(S.fx==='pet') S.fx=null; },1500);
        msg(['なでなで～！きもちいい！','もっとなでて～！','えへへ♪','うれしいな！'][Math.min(petCount-1,3)]);
        updateUI();
      }
    } else {
      const ms=['どこさわってるの？','こっちだよ～！','そこじゃないよ！'];
      msg(ms[Math.floor(Math.random()*ms.length)]);
    }
  }

  function showNameOverlay(){
    const ol=document.getElementById('ikNameOverlay');
    const lbl=document.getElementById('ikNameColorLabel');
    const inp=document.getElementById('ikNameInput');
    lbl.textContent=S.color===3
      ?'🌈 レアカラー！レインボーいろのインコ！'
      :`✨ ${PALETTES[S.color].name}いろのインコ`;
    inp.value='';
    ol.style.display='flex';
    setTimeout(()=>inp.focus(),100);
  }

  window.ikSubmitName=function(){
    const inp=document.getElementById('ikNameInput');
    S.name=inp.value.trim()||'インコっち';
    document.getElementById('ikNameOverlay').style.display='none';
    continueEvolve(1);
  };

  function continueEvolve(next){
    awaitingName=false;
    S.stage=next; S.fx='evolve';
    sndEvolve(); showBirthOverlay();
    setTimeout(()=>{ S.fx=null; },2000);
    msg(`✨ ${getStageName()}が生まれたよ！`);
    const sc=document.getElementById('ikScreen');
    sc.style.boxShadow='0 0 30px #ffd700';
    setTimeout(()=>{ sc.style.boxShadow=''; },2500);
    saveState();
    updateUI();
  }

  function showBirthOverlay(){
    const p=getP();
    const ol=document.getElementById('ikBirthOverlay');
    const txt=document.getElementById('ikBirthText');
    const sub=document.getElementById('ikBirthSub');
    if(S.color===3){
      txt.textContent=`🌈 ${S.name}`;
      sub.textContent='レインボーいろのレアインコ！';
    } else {
      txt.textContent=`✨ ${p.name}の ${S.name} ✨`;
      sub.textContent='たまごからうまれたよ！';
    }
    ol.style.display='flex';
    setTimeout(()=>{ ol.style.display='none'; },3000);
  }

  function triggerDeath(){
    if(S.dead) return;
    S.dead=true; sndDeath();
    const entry={name:S.name||'インコっち',color:S.color??2,age:S.age,diedAt:Date.now()};
    saveGrave(entry);
    renderGrave();
    const nm=S.name||'インコっち';
    msg(`${nm}はそらへたびだった... 🌈`);
    document.getElementById('ikScreen').style.boxShadow='0 0 40px rgba(255,255,255,0.5)';
    setTimeout(()=>{
      document.getElementById('ikScreen').style.boxShadow='';
      Object.assign(S,{stage:0,hunger:100,happy:100,energy:100,age:0,
        sleeping:false,fx:null,color:null,name:null,dead:false,eatPhase:0,
        bowl:100,water:100,clean:100,poops:[]});
      document.getElementById('ikIcoSleep').textContent='💤';
      document.getElementById('ikLblSleep').textContent='ねかせる';
      saveState();
      updateUI();
      msg('あたらしいたまごがあった！');
    },4000);
  }

  function saveGrave(entry){
    const raw=localStorage.getItem('inkocchi_grave');
    const list=raw?JSON.parse(raw):[];
    list.push(entry);
    localStorage.setItem('inkocchi_grave',JSON.stringify(list));
  }

  function renderGrave(){
    const raw=localStorage.getItem('inkocchi_grave');
    const list=raw?JSON.parse(raw):[];
    const el=document.getElementById('ikGraveyard');
    const listEl=document.getElementById('ikGraveList');
    if(!list.length){ el.style.display='none'; return; }
    el.style.display='block';
    const cIcon={0:'💛',1:'💙',2:'💚',3:'🌈'};
    listEl.innerHTML=list.map(g=>`<div class="ik-grave-item">
      <div class="ik-grave-icon">🪦</div>
      <div class="ik-grave-name">${cIcon[g.color??2]||'💚'} ${g.name||'インコっち'}</div>
      <div class="ik-grave-age">${g.age}日生きた</div>
    </div>`).join('');
  }

  window.ikToggleSound=function(){
    soundOn=!soundOn;
    const btn=document.getElementById('ikSndBtn');
    btn.textContent=soundOn?'🔊':'🔇';
    btn.classList.toggle('ik-snd-on',soundOn);
  };

  window.ikReset=function(){
    if(!confirm('すべてのデータを初期化しますか？\nインコの記録もすべて消えます。')) return;
    localStorage.removeItem('inkocchi');
    localStorage.removeItem('inkocchi_grave');
    location.reload();
  };

  window.ikAction = function(type){
    if(S.stage===0){ msg('まだたまごだよ。もうすこしまってね...'); return; }
    if(S.sleeping&&type==='play'){ msg('いまねてるよ...そっとしといて...'); return; }
    if(type==='feed'){
      if(S.bowl>=100){ msg('えさいれはまだいっぱいだよ！'); return; }
      S.bowl=100; S.eatPhase=24; S.fx='feed';
      sndFeed(); setTimeout(()=>S.fx=null,2500); msg('えさを補充したよ！もぐもぐ♪');
    } else if(type==='water'){
      if(S.water>=100){ msg('みずいれはまだいっぱいだよ！'); return; }
      S.water=100;
      S.fx='water'; setTimeout(()=>{ if(S.fx==='water') S.fx=null; },2000);
      sndWater(); msg('みずを補充したよ！おいしそう！');
    } else if(type==='clean'){
      if(S.poops.length===0){ msg('ケージはきれいだよ！そうじしなくていい！'); return; }
      S.poops=[]; S.clean=Math.min(100,S.clean+50);
      sndClean(); msg('そうじしたよ！ケージがぴかぴかになったね！');
    } else if(type==='play'){
      if(S.energy<14){ msg('つかれてあそべないよ...ねかせて...'); return; }
      S.happy=Math.min(100,S.happy+16); S.energy=Math.max(0,S.energy-12);
      sndPlay(); S.fx='play'; setTimeout(()=>S.fx=null,2500); msg('やったー！たのしいな♪');
    } else if(type==='sleep'){
      if(S.sleeping){
        S.sleeping=false; S.fx=null;
        document.getElementById('ikIcoSleep').textContent='💤';
        document.getElementById('ikLblSleep').textContent='ねかせる';
        sndWakeup(); msg('おはよう！よくねれたよ！');
      } else {
        S.sleeping=true; S.fx='sleep';
        document.getElementById('ikIcoSleep').textContent='☀️';
        document.getElementById('ikLblSleep').textContent='おこす';
        sndSleep(); msg('おやすみ...zzz');
      }
    }
    updateUI();
  };

  function msg(t){ document.getElementById('ikMsg').textContent=t; }

  function updateUI(){
    const bars=[
      ['ikHgBar','ikHgVal',S.hunger,'hunger'],
      ['ikHpBar','ikHpVal',S.happy,'happy'],
      ['ikEnBar','ikEnVal',S.energy,'energy'],
      ['ikClBar','ikClVal',S.clean,'clean'],
    ];
    bars.forEach(([bid,vid,val,type])=>{
      const bar=document.getElementById(bid);
      bar.style.width=val+'%';
      if(val<30){
        bar.style.background=type==='hunger'?'#ff4444':type==='happy'?'#cc7700':type==='energy'?'#0066aa':'#554400';
      } else {
        bar.style.background=type==='hunger'?'linear-gradient(90deg,#ff7b7b,#ffb07a)':type==='happy'?'linear-gradient(90deg,#ffd700,#fff176)':type==='energy'?'linear-gradient(90deg,#00e676,#69ffb4)':'linear-gradient(90deg,#00ccaa,#44ffdd)';
      }
      document.getElementById(vid).textContent=Math.round(val);
    });
    document.getElementById('ikStageLabel').textContent=`▷ ${getStageName()} ◁`;
    document.getElementById('ikAge').textContent=S.name
      ?`生後 ${S.age} 日（${STAGE_NAMES[S.stage]}） 寿命 ${S.lifespan} 日`
      :`生後 ${S.age} 日`;
  }

  // ─── SAVE / LOAD ───────────────────────────
  function saveState(){
    localStorage.setItem('inkocchi',JSON.stringify({
      stage:S.stage,hunger:S.hunger,happy:S.happy,energy:S.energy,
      age:S.age,sleeping:S.sleeping,color:S.color,name:S.name,
      dead:S.dead,lifespan:S.lifespan,lifePts:S.lifePts,
      bowl:S.bowl,water:S.water,clean:S.clean,poops:S.poops,
      savedAt:Date.now()
    }));
  }

  function loadState(){
    const raw=localStorage.getItem('inkocchi'); if(!raw) return;
    try {
      const d=JSON.parse(raw);
      S.stage=d.stage??0; S.hunger=d.hunger??100; S.happy=d.happy??100;
      S.energy=d.energy??100; S.age=d.age??0; S.sleeping=d.sleeping??false;
      S.color=d.color??null;
      if(S.color===null&&S.stage>0) S.color=Math.floor(Math.random()*3);
      S.name=d.name??null;
      S.dead=d.dead??false;
      S.lifespan=d.lifespan??14;
      S.lifePts=d.lifePts??0;
      S.bowl=d.bowl??100;
      S.water=d.water??100;
      S.clean=d.clean??100;
      S.poops=d.poops??[];
      if(S.sleeping){
        document.getElementById('ikIcoSleep').textContent='☀️';
        document.getElementById('ikLblSleep').textContent='おこす';
      }
      if(d.savedAt){
        const mins=(Date.now()-d.savedAt)/60000;
        const daysElapsed=Math.floor(mins/3);
        if(daysElapsed>0) S.age+=daysElapsed;
        if(S.stage>0&&!S.sleeping){
          S.hunger=Math.max(0,S.hunger-mins*0.25);
          S.happy=Math.max(0,S.happy-mins*0.13);
          S.energy=Math.max(0,S.energy-mins*0.25);
          S.bowl=Math.max(0,S.bowl-mins*14);
          S.water=Math.max(0,S.water-mins*11);
          S.clean=Math.max(0,S.clean-mins*2);
        }
        msg(`おかえり！${Math.round(mins)}ぷんぶりだね！`);
      }
    } catch(e){}
  }
})();
</script>
