    ctx.fillStyle='rgba(200,160,100,0.25)'; ctx.beginPath(); ctx.ellipse(ox+8,oy+10,16,22,0.4,0,Math.PI*2); ctx.fill();
    ctx.fillStyle='rgba(255,255,255,0.35)'; ctx.beginPath(); ctx.ellipse(ox-8,oy-8,9,14,-0.3,0,Math.PI*2); ctx.fill();
    if(S.age>=1){
