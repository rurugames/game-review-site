<style>
  .gallery-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
  }
  .gallery-header {
    text-align: center;
    margin-bottom: 30px;
  }

  /* フォルダ（シリーズ）カードグリッド */
  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
  }
  .series-card {
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .series-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 16px rgba(0,0,0,0.15);
  }
  .series-cover {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    background: #f0f0f0;
  }
  .series-cover-placeholder {
    width: 100%;
    aspect-ratio: 3 / 2;
    background: linear-gradient(135deg, #e8e8e8, #d0d0d0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
    color: #aaa;
  }
  .series-info {
    padding: 12px 14px;
  }
  .series-name {
    font-size: 15px;
    font-weight: bold;
    color: #222;
    margin: 0 0 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .series-count {
    font-size: 12px;
    color: #888;
  }

  /* レスポンシブ */
  @media (max-width: 600px) {
    .series-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }
  }

  /* おすすめ動画ウィジェット */
  .rec-video-widget {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    background: #1a1a2e;
    border-radius: 10px;
    padding: 14px;
    margin: 40px auto 20px;
    max-width: 800px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }
  .rec-video-widget:hover { background: #22223b; }
  .rec-video-thumb {
    width: 140px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
  }
  .rec-video-thumb img {
    width: 100%;
    display: block;
    object-fit: cover;
    aspect-ratio: 16/9;
  }
  .rec-video-body { flex: 1; min-width: 0; }
  .rec-video-label {
    font-size: 11px;
    color: #ff4e6a;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .rec-video-title {
    font-size: 14px;
    font-weight: bold;
    color: #fff;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rec-video-date {
    font-size: 11px;
    color: #999;
    margin-top: 6px;
  }
  @media (max-width: 480px) {
    .rec-video-thumb { width: 100px; }
  }
</style>

<div class="gallery-container">
  <div class="gallery-header">
    <h1>ギャラリー</h1>
    <p>アニメ・ゲームキャラクターイラスト</p>
  </div>

  <div class="series-grid">
    <% if (folders && folders.length > 0) { %>
      <% folders.forEach(function(f) { %>
        <a href="/gallery/series/<%= encodeURIComponent(f._id) %>" class="series-card">
          <% if (f.cover) { %>
            <img src="<%= f.cover %>" alt="<%= f._id %>" class="series-cover" loading="lazy">
          <% } else { %>
            <div class="series-cover-placeholder">🖼</div>
          <% } %>
          <div class="series-info">
            <p class="series-name" title="<%= f._id %>"><%= f._id %></p>
            <p class="series-count"><%= f.count %> 枚</p>
          </div>
        </a>
      <% }); %>
    <% } else { %>
      <div style="grid-column: 1 / -1; text-align: center; padding: 60px;">
        <p>現在表示できる画像がありません。</p>
      </div>
    <% } %>
  </div>

  <!-- おすすめ動画（下部） -->
  <% if (typeof randomVideo !== 'undefined' && randomVideo) { %>
    <a href="<%= randomVideo.url %>" target="_blank" rel="noopener" class="rec-video-widget" style="color: inherit;">
      <div class="rec-video-thumb">
        <% if (randomVideo.thumbnailUrl) { %>
          <img src="<%= randomVideo.thumbnailUrl %>" alt="<%= randomVideo.title %>" loading="lazy">
        <% } else { %>
          <img src="/images/siteicon.png" alt="thumb" loading="lazy">
        <% } %>
      </div>
      <div class="rec-video-body">
        <div class="rec-video-label">▶ おすすめ動画</div>
        <div class="rec-video-title"><%= randomVideo.title %></div>
        <div class="rec-video-date"><%= randomVideo.publishedAtJp || '' %></div>
      </div>
    </a>
  <% } %>
</div>
