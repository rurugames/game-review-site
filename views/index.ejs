                <span class="date"><%= v.publishedAtJp || '' %></span>
              </div>
              <a href="<%= v.url %>" target="_blank" rel="noopener" class="btn-read-more">YouTubeで見る</a>
            </div>
          </article>
        <% }); %>
      </div>
    </div>
  </div>
</section>
<% } %>

