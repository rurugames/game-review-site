<style>
.fv-form-container {
  max-width: 760px;
  margin: 0 auto;
  padding: 1.5rem 1rem;
}
.fv-form-container h1 { margin-bottom: 1.25rem; }
.form-group { margin-bottom: 1.1rem; }
.form-group label {
  display: block;
  font-weight: bold;
  margin-bottom: 0.3rem;
}
.form-group input[type="text"],
.form-group input[type="url"],
.form-group input[type="number"],
.form-group textarea,
.form-group select {
  width: 100%;
  padding: 0.5rem 0.65rem;
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 0.95rem;
  box-sizing: border-box;
}
.form-group textarea { resize: vertical; }
.form-hint {
  font-size: 0.8rem;
  color: #888;
  margin-top: 0.25rem;
}
.form-actions {
  display: flex;
  gap: 0.75rem;
  margin-top: 1.5rem;
  flex-wrap: wrap;
}
</style>

<div class="fv-form-container">
  <h1>無料動画を編集</h1>

  <form action="/free-videos/<%= video._id %>?_method=PUT" method="POST">
    <div class="form-group">
      <label for="title">タイトル <span style="color:red">*</span></label>
      <input type="text" id="title" name="title" required value="<%= video.title %>">
    </div>

    <div class="form-group">
      <label for="affiliateLink">アフィリエイトリンク（URL） <span style="color:red">*</span></label>
      <input type="url" id="affiliateLink" name="affiliateLink" required value="<%= video.affiliateLink %>">
    </div>

    <div class="form-group">
      <label for="imageUrl">サムネイルURL</label>
      <input type="url" id="imageUrl" name="imageUrl" value="<%= video.imageUrl || '' %>">
    </div>

    <div class="form-group">
      <label for="actress">出演者（カンマ区切り）</label>
      <input type="text" id="actress" name="actress" value="<%= (video.actress || []).join(', ') %>">
      <p class="form-hint">例: 花守夏歩, 依本しおり</p>
    </div>

    <div class="form-group">
      <label for="series">シリーズ</label>
      <input type="text" id="series" name="series" value="<%= video.series || '' %>">
    </div>

    <div class="form-group">
      <label for="maker">メーカー</label>
      <input type="text" id="maker" name="maker" value="<%= video.maker || '' %>">
    </div>

    <div class="form-group">
      <label for="tags">タグ（カンマ区切り）</label>
      <input type="text" id="tags" name="tags" value="<%= (video.tags || []).join(', ') %>">
      <p class="form-hint">例: フェラ, 中出し, 美少女</p>
    </div>

    <div class="form-group">
      <label for="viewCount">再生回数</label>
      <input type="number" id="viewCount" name="viewCount" min="0" value="<%= video.viewCount || '' %>">
    </div>

    <div class="form-group">
      <label for="description">説明文 <span style="color:red">*</span></label>
      <textarea id="description" name="description" rows="6" required><%= video.description %></textarea>
    </div>

    <div class="form-group">
      <label for="status">公開ステータス</label>
      <select id="status" name="status">
        <option value="published" <%= video.status === 'published' ? 'selected' : '' %>>公開</option>
        <option value="draft" <%= video.status === 'draft' ? 'selected' : '' %>>下書き</option>
      </select>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-primary">更新する</button>
      <a href="/admin/free-videos" class="btn-secondary">キャンセル</a>
    </div>
  </form>
</div>
