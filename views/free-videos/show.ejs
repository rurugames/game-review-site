<style>
.fv-show-container {
  max-width: 820px;
  margin: 0 auto;
  padding: 1.5rem 1rem;
}
.fv-show-header { margin-bottom: 1.25rem; }
.fv-show-title {
  font-size: 1.4rem;
  font-weight: bold;
  margin: 0 0 0.4rem;
  line-height: 1.35;
}
.fv-show-meta {
  font-size: 0.82rem;
  color: #888;
  margin-bottom: 0.6rem;
}
.fv-genre-tag {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: bold;
  color: #fff;
  background: #e83c5a;
  border-radius: 3px;
  padding: 1px 7px;
  margin-right: 6px;
  vertical-align: middle;
}
.fv-thumb-link {
  display: block;
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 1rem;
  position: relative;
}
.fv-thumb-link img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}
.fv-play-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.55);
  border-radius: 50%;
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  color: #fff;
  pointer-events: none;
}
.fv-cta {
  margin-bottom: 1.25rem;
  text-align: center;
}
.fv-cta a {
  display: inline-block;
  background: #e83c5a;
  color: #fff;
  padding: 0.65rem 2rem;
  border-radius: 6px;
  font-weight: bold;
  text-decoration: none;
  font-size: 1rem;
  transition: background 0.2s;
}
.fv-cta a:hover { background: #c72e47; }
.fv-info-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 1.25rem;
  font-size: 0.9rem;
}
.fv-info-table th,
.fv-info-table td {
  padding: 0.45rem 0.75rem;
  border-bottom: 1px solid #eee;
  text-align: left;
  vertical-align: top;
}
.fv-info-table th {
  width: 7rem;
  color: #888;
  font-weight: normal;
  white-space: nowrap;
}
.fv-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-bottom: 1.25rem;
}
.fv-tag {
  font-size: 0.78rem;
  background: #f0f0f0;
  border-radius: 4px;
  padding: 2px 8px;
  color: #555;
}
.fv-description {
  line-height: 1.8;
  font-size: 0.95rem;
  margin-bottom: 1.5rem;
  white-space: pre-wrap;
}
.fv-views {
  font-size: 0.88rem;
  color: #e83c5a;
  font-weight: bold;
  margin-bottom: 1rem;
}
.fv-show-actions {
  margin-top: 1.5rem;
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}
</style>

<div class="fv-show-container">
  <div class="fv-show-header">
    <h1 class="fv-show-title"><%= video.title %></h1>
    <div class="fv-show-meta">
      <span class="fv-genre-tag">FANZA無料動画</span>
      &nbsp;<%= new Date(video.createdAt).toLocaleDateString('ja-JP') %>
    </div>
    <% if (video.viewCount) { %>
      <div class="fv-views">&#9654; 再生回数 <%= video.viewCount.toLocaleString() %>回</div>
    <% } %>
  </div>

  <% const _showThumb = video.imageUrl || getFreeVideoThumbnail(video.affiliateLink); %>
  <% if (_showThumb) { %>
    <a href="<%= video.affiliateLink %>" target="_blank" rel="noopener sponsored" class="fv-thumb-link">
      <img src="<%= _showThumb %>" alt="<%= video.title %>" loading="lazy">
      <div class="fv-play-overlay">&#9654;</div>
    </a>
  <% } %>

  <div class="fv-cta">
    <a href="<%= video.affiliateLink %>" target="_blank" rel="noopener sponsored">&#9654; 無料で視聴する（FANZA）</a>
  </div>

  <% if ((video.actress && video.actress.length > 0) || video.maker || video.series) { %>
  <table class="fv-info-table">
    <% if (video.actress && video.actress.length > 0) { %>
    <tr>
      <th>出演者</th>
      <td><%= video.actress.join(' / ') %></td>
    </tr>
    <% } %>
    <% if (video.series) { %>
    <tr>
      <th>シリーズ</th>
      <td><%= video.series %></td>
    </tr>
    <% } %>
    <% if (video.maker) { %>
    <tr>
      <th>メーカー</th>
      <td><%= video.maker %></td>
    </tr>
    <% } %>
  </table>
  <% } %>

  <% if (video.tags && video.tags.length > 0) { %>
  <div class="fv-tags">
    <% video.tags.forEach(function(t) { %>
      <span class="fv-tag"># <%= t %></span>
    <% }) %>
  </div>
  <% } %>

  <div class="fv-description"><%= video.description %></div>

  <% if (typeof adTag !== 'undefined' && adTag) { %>
  <div style="text-align:center; margin: 1.5rem 0;"><%- adTag %></div>
  <% } %>

  <div class="fv-show-actions">
    <a href="/free-videos" class="btn-secondary">← 一覧に戻る</a>
    <% if (isAdmin) { %>
      <a href="/free-videos/<%= video._id %>/edit" class="btn-secondary">編集</a>
      <form action="/free-videos/<%= video._id %>?_method=DELETE" method="POST"
            onsubmit="return confirm('この動画を削除しますか？')">
        <button type="submit" class="btn-delete" style="cursor:pointer;">削除</button>
      </form>
    <% } %>
  </div>
</div>
