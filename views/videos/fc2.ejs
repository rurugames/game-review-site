<section class="articles-section page-section">
  <style>
    .fc2-embed {
      position: relative;
      width: 100%;
    }
    .fc2-embed::before {
      content: "";
      display: block;
      padding-top: 56.25%;
    }
    .fc2-embed .fc2-embed-inner {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
    .fc2-embed iframe,
    .fc2-embed embed,
    .fc2-embed object {
      width: 100% !important;
      height: 100% !important;
    }
  </style>

  <div class="page-header">
    <div class="channel-header">
      <div class="channel-brand">
        <img src="/images/siteicon.png" alt="R18Hub" class="channel-icon" loading="lazy">
        <div>
          <h1 class="section-title" style="margin-bottom: 0.1rem;">FC2動画</h1>
          <p class="section-lead" style="margin: 0;">成人向け動画（18+）の紹介一覧です。</p>
          <div class="meta-row" style="margin-top: 0.35rem; flex-wrap: wrap;">
            <span class="tag">18+（年齢確認済）</span>
            <span class="tag">ページ内で再生</span>
          </div>
          <% const __cacheAgeHours = cacheTs ? ((Date.now() - new Date(cacheTs).getTime()) / (1000 * 60 * 60)) : null; %>
          <% if (cacheTsJp) { %>
            <p class="section-lead" style="margin: 0.25rem 0 0 0; font-size: 0.95rem;">最終更新: <%= cacheTsJp %></p>
          <% } %>
          <% if (__cacheAgeHours !== null && Number.isFinite(__cacheAgeHours) && __cacheAgeHours > 6) { %>
            <p class="section-lead" style="margin: 0.15rem 0 0 0; font-size: 0.92rem;">更新が遅れています（表示はキャッシュ）</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <% if ((!latestVideos || latestVideos.length === 0) && (!popularVideos || popularVideos.length === 0)) { %>
    <div class="panel">
      <div class="panel-body">
        <p class="section-lead">現在表示できる動画がありません。しばらくしてから再読み込みしてください。</p>
      </div>
    </div>
  <% } %>

  <div class="page-header" style="margin-top: 1.25rem;">
    <h2 class="section-title" style="font-size: 1.4rem;">カテゴリ：アニメ・エロゲ</h2>
    <p class="section-lead">FC2カテゴリ検索（最大5件）</p>
  </div>

  <% if (animeErogeVideos && animeErogeVideos.length > 0) { %>
    <div class="articles-grid modern-grid">
      <% animeErogeVideos.slice(0, 5).forEach(function(v, idx){ %>
        <div class="panel">
          <div class="panel-body">
            <article class="post-card">
              <div class="post-cover fc2-embed">
                <div class="fc2-embed-inner">
                  <script src="//static.fc2.com/video/js/outerplayer.min.js"
                    url="<%= v.url %>"
                    tk="<%= fc2OuterPlayerTk %>"
                    tl="<%= v.title %>"
                    d="<%= fc2OuterPlayerDigestD %>"
                    w="<%= fc2OuterPlayerWidth %>"
                    h="<%= fc2OuterPlayerHeight %>"
                    suggest="on"
                    charset="UTF-8"></script>
                </div>
              </div>
              <div class="post-body">
                <div class="meta-row">
                  <span class="tag genre">FC2</span>
                  <span class="tag">アニメ・エロゲ</span>
                  <% if (v.publishedAtJp) { %>
                    <span class="tag"><%= v.publishedAtJp %></span>
                  <% } %>
                </div>
                <h3 class="post-title text-truncate-2">
                  <a href="/out?u=<%= encodeURIComponent(v.url) %>&k=fc2&s=anime_eroge&vid=<%= encodeURIComponent(v.id || '') %>&pos=<%= (idx + 1) %>" target="_blank" rel="noopener noreferrer nofollow"><%= v.title %></a>
                </h3>
                <% if (v.tags && v.tags.length > 0) { %>
                  <div class="tags-row" style="margin-top:0.5rem; display:flex; gap:0.25rem; flex-wrap:wrap;">
                    <% v.tags.slice(0, 3).forEach(function(t){ %>
                      <span class="tag"><%= t %></span>
                    <% }); %>
                  </div>
                <% } %>
              </div>
            </article>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="panel">
      <div class="panel-body">
        <p class="section-lead">該当する動画が見つかりませんでした。</p>
      </div>
    </div>
  <% } %>

  <% if (latestVideos && latestVideos.length > 0) { %>
    <div class="page-header" style="margin-top: 1.25rem;">
      <h2 class="section-title" style="font-size: 1.4rem;">新着</h2>
      <p class="section-lead">追加順（最大5件）</p>
    </div>

    <div class="articles-grid modern-grid">
      <% latestVideos.slice(0, 5).forEach(function(v, idx){ %>
        <div class="panel">
          <div class="panel-body">
            <article class="post-card">
              <div class="post-cover fc2-embed">
                <div class="fc2-embed-inner">
                  <script src="//static.fc2.com/video/js/outerplayer.min.js"
                    url="<%= v.url %>"
                    tk="<%= fc2OuterPlayerTk %>"
                    tl="<%= v.title %>"
                    d="<%= fc2OuterPlayerDigestD %>"
                    w="<%= fc2OuterPlayerWidth %>"
                    h="<%= fc2OuterPlayerHeight %>"
                    suggest="on"
                    charset="UTF-8"></script>
                </div>
              </div>
              <div class="post-body">
                <div class="meta-row">
                  <span class="tag genre">FC2</span>
                  <span class="tag">新着（追加順）</span>
                  <% if (v.publishedAtJp) { %>
                    <span class="tag"><%= v.publishedAtJp %></span>
                  <% } %>
                </div>
                <h3 class="post-title text-truncate-2">
                  <a href="/out?u=<%= encodeURIComponent(v.url) %>&k=fc2&s=latest&vid=<%= encodeURIComponent(v.id || '') %>&pos=<%= (idx + 1) %>" target="_blank" rel="noopener noreferrer nofollow"><%= v.title %></a>
                </h3>
                <% if (v.tags && v.tags.length > 0) { %>
                  <div class="tags-row" style="margin-top:0.5rem; display:flex; gap:0.25rem; flex-wrap:wrap;">
                    <% v.tags.slice(0, 3).forEach(function(t){ %>
                      <span class="tag"><%= t %></span>
                    <% }); %>
                  </div>
                <% } %>
              </div>
            </article>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>

  <% if (popularVideos && popularVideos.length > 0) { %>
    <div class="page-header" style="margin-top: 1.25rem;">
      <h2 class="section-title" style="font-size: 1.4rem;">人気</h2>
      <p class="section-lead">トレンド（最大5件）</p>
    </div>

    <div class="articles-grid modern-grid">
      <% popularVideos.slice(0, 5).forEach(function(v, idx){ %>
        <div class="panel">
          <div class="panel-body">
            <article class="post-card">
              <div class="post-cover fc2-embed">
                <div class="fc2-embed-inner">
                  <script src="//static.fc2.com/video/js/outerplayer.min.js"
                    url="<%= v.url %>"
                    tk="<%= fc2OuterPlayerTk %>"
                    tl="<%= v.title %>"
                    d="<%= fc2OuterPlayerDigestD %>"
                    w="<%= fc2OuterPlayerWidth %>"
                    h="<%= fc2OuterPlayerHeight %>"
                    suggest="on"
                    charset="UTF-8"></script>
                </div>
              </div>
              <div class="post-body">
                <div class="meta-row">
                  <span class="tag genre">FC2</span>
                  <span class="tag">人気（トレンド）</span>
                  <% if (v.publishedAtJp) { %>
                    <span class="tag"><%= v.publishedAtJp %></span>
                  <% } %>
                </div>
                <h3 class="post-title text-truncate-2">
                  <a href="/out?u=<%= encodeURIComponent(v.url) %>&k=fc2&s=popular&vid=<%= encodeURIComponent(v.id || '') %>&pos=<%= (idx + 1) %>" target="_blank" rel="noopener noreferrer nofollow"><%= v.title %></a>
                </h3>
                <% if (v.tags && v.tags.length > 0) { %>
                  <div class="tags-row" style="margin-top:0.5rem; display:flex; gap:0.25rem; flex-wrap:wrap;">
                    <% v.tags.slice(0, 3).forEach(function(t){ %>
                      <span class="tag"><%= t %></span>
                    <% }); %>
                  </div>
                <% } %>
              </div>
            </article>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</section>
